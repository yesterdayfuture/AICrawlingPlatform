# ===== 数据库配置 =====
# SQLite（默认，启动时自动建表）
DATABASE_URL=sqlite:///./crawler.db
# PostgreSQL 切换示例：
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/dbname

# ===== CORS 配置 =====
# 允许的前端跨域来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== 超时配置（秒） =====
# 大模型调用超时
LLM_TIMEOUT=120
# 爬虫请求超时
CRAWLER_TIMEOUT=30
